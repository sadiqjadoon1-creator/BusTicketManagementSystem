## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
.vscode/

# NuGet
*.nupkg
*.snupkg
.nuget/

# Node modules (for Angular)
node_modules/

# Angular
dist/
.angular/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
appsettings.local.json
